nav.navbar
    .container
        a.logo(href="/")
            img.logo-image(src="/images/logo.svg", alt="Laydex logo")
        .navbar-links
            button.link-outline-icon
                img.icon(src="/icons/search.svg", alt="image")
            .drop-down
                a.link-outline(href="/") SERVICES +
                .drop-down-content
                    a.link-outline(href="/") DISTRIBUTION DIVISION
                    a.link-outline(href="/") SPECIFICATION DIVISION
                    a.link-outline(href="/") CPD
                    a.link-outline(href="/") TECHNICAL RESOURCES
            a.link-outline(href="/about.html") ABOUT US
            .drop-down
                a.link-outline(href="/products.html") PRODUCTS +
                .drop-down-content
                    a.link-outline(href="/products.html") BUILDING PRODUCTS
                    a.link-outline(href="/products.html") flooring
                    a.link-outline(href="/products.html") passive fire protection
                    a.link-outline(href="/products-roofing.html") roofing
                    a.link-outline(href="/products.html") radon & gas protection
                    button.link-outline(data-panel-trigger="products") ALL PRODUCTS
            a.link-outline(href="/") Sales Contacts
            a.link-outline(href="/") Contact US
            a.link-outline(href="/login.html")
                | LOG IN
                img.icon(src="/icons/user.svg", alt="image")
            button.hamb-btn
                .divider
                .divider
                .divider

