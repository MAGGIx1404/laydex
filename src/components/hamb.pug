//- Nested accordion mixin for the hamburger menu.
//- `cls` sets the depth style (lvl-1 / lvl-2 / lvl-3).
mixin hambAcc(title, cls)
    .hamb-accordion(class=cls)
        button.hamb-accordion-trigger(type="button")
            span.hamb-accordion-title= title
            span.hamb-accordion-icon
        .hamb-accordion-content
            .hamb-accordion-content-inner
                block

