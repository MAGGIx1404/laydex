.hamb-menu
    .hamb-menu-inner
        +hambAcc('Services', 'lvl-1')
            a.hamb-link(href="/") Distribution Division
            a.hamb-link(href="/") Specification Division
            a.hamb-link(href="/") CPD
            a.hamb-link(href="/") Technical Resources

        a.hamb-link.lvl-1(href="/about.html") About Us

        +hambAcc('Products', 'lvl-1')
            +hambAcc('Building Products', 'lvl-2')
                each cat in buildingProducts
                    +hambAcc(cat.name, 'lvl-3')
                        if cat.items
                            each item in cat.items
                                a.hamb-link(href="/products.html")= item
                        if cat.subcategories
                            each sub in cat.subcategories
                                +hambAcc(sub.name, 'lvl-4')
                                    each item in sub.items
                                        a.hamb-link(href="/products.html")= item
            each family in productFamilies
                +hambAcc(family, 'lvl-2')
                    a.hamb-link(href="/products.html") Explore range

        a.hamb-link.lvl-1(href="/") Sales Contact
        a.hamb-link.lvl-1(href="/") Contact Us
        a.hamb-link.lvl-1(href="/login.html") Log In
