nav.navbar
    .container
        a.logo(href="/")
            img.logo-image(src="/images/logo.svg", alt="Laydex logo")
        .navbar-links
            .search-wrapper
                button.link-outline-icon.search-trigger
                    img.icon(src="/icons/search.svg", alt="image")
                    .close-icon
                        .divider
                        .divider
                .search-box
                    .search-form
                        input(type="text", placeholder="Search products...")
                        button.link-outline-icon.search-btn
                            img.icon(src="/icons/search.svg", alt="image")
            a.link-outline.fill-orange(href="/") DISTRIBUTION
            a.link-outline(href="/about.html") ABOUT US
            .drop-down
                a.link-outline(href="/products.html") PRODUCTS +
                .drop-down-content
                    button.link-outline(data-panel-trigger="products") ALL PRODUCTS
                    a.link-outline(href="/products.html") BUILDING PRODUCTS
                    a.link-outline(href="/products.html") flooring
                    a.link-outline(href="/products.html") passive fire protection
                    a.link-outline(href="/products-roofing.html") roofing
                    a.link-outline(href="/products.html") radon & gas protection
            a.link-outline(href="/") Sales Contacts
            a.link-outline(href="/") Contact US
            a.link-outline(href="/login.html")
                | LOG IN
                img.icon(src="/icons/user.svg", alt="image")
            button.hamb-btn
                .divider
                .divider
                .divider

.panel(data-panel="products")
    .panel-inner
        .panel-top
            h3
                img.icon(src="/icons/cap.svg", alt="image")
                | Building Products
            .btns-wrapper
                button.link-outline.active(data-tab="all") BUILDING PRODUCTS
                button.link-outline(data-tab="1") ROOFING
                button.link-outline(data-tab="2") FLOORING
                button.link-outline(data-tab="3") PASSIVE FIRE PROTECTION
                button.link-outline(data-tab="4") RADON & GAS PROTECTION
            button.close-btn Close
        .panel-grid
            each cat in buildingProducts
                .accordion(data-tab-content=cat.category)
                    .accordion-trigger
                        h6
                            | #{cat.name}&nbsp;
                            span.accordion-icon +
                    .accordion-content
                        .accordion-content-inner
                            if cat.items
                                each item in cat.items
                                    a.link(href="/products.html")= item
                            if cat.subcategories
                                each sub in cat.subcategories
                                    .accordion.accordion-nested
                                        .accordion-trigger
                                            span.nested-title
                                                | #{sub.name}&nbsp;
                                                span.accordion-icon +
                                        .accordion-content
                                            .accordion-content-inner
                                                each item in sub.items
                                                    a.link(href="/products.html")= item
                            if cat.itemsAfter
                                each item in cat.itemsAfter
                                    a.link(href="/products.html")= item
