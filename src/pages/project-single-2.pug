extends /layouts/blue

block content
    section.banner
        .container.content-bottom
            .content-box
                h1(data-animation="reveal") Residential Green Roof Project.<br/> The Paddocks, Newbridge
        .bg
            img.image(src="/images/projects/banner-2.png", alt="image")

    section.case-study.bg-blue
        .container
            .case-panel
                figure.case-figure(data-animation="reveal")
                    img.image(src="/images/projects/image-2.png", alt="image")
                .content-box(data-animation="reveal" data-animation-delay="100")
                    +tag('CASE STUDY', 'white')
                    h3
                        img.icon(src="/icons/doc.svg", alt="image")
                        | Project Overview
                    p The Paddocks’ is an impressive residential development in Newbridge, Co. Kildare, consisting of both houses and apartment blocks, and developed by main contractor, Montane Developments.
                    p This project focused on the residential green roof of the apartment blocks, comprised of over 250 1-, 2- and 3-bedroom apartments, and is being completed by the expert roofing contractors, Titan Roofing. Currently there are 3 blocks completed with work still ongoing on the remainder.
                    p
                        | ‘The Paddocks’ apartments residential roof project features&nbsp;
                        a(href="/") Pluvitec Maxitec, the perfect anti-root solution for a Green Roof
                        |  along with a&nbsp;
                        a(href="/") sedum green roof area
                        |  and stone perimeter. The cladding on the penthouses of each apartment block feature our&nbsp;
                        a(href="/") Lindab SRP25
                        |  steel snap-lock system providing a clean, modern finish. Finally,&nbsp;
                        a(href="/") Renolit ALKORPLAN PVC
                        |  membrane is featured on the lower flat roof surfaces (e.g. bicycle and rubbish bin sheds).

            .case-details
                .case-detail-box(data-animation="reveal" data-animation-delay="200")
                    h4
                        img.icon(src="/icons/feature.svg", alt="image")
                        | Featured Products
                    p
                        strong
                            a(href="/") Pluvitec MAXITEC Anti-Root Membrane:
                        |  A pre-fabricated membrane designed for use on structures where vegetation is foreseen to prevent penetration by roots.
                    p
                        strong
                            a(href="/") Lindab SRP25:
                        |  Metal Roofing System – 0.6mm Steel Snap Lock System.
                    p
                        strong
                            a(href="/") Renolit ALKORPLAN PVC:
                        |  A mechanically fixed single Ply PVC membrane.

                .case-detail-box(data-animation="reveal" data-animation-delay="300")
                    h4
                        img.icon(src="/icons/facts.svg", alt="image")
                        | Project Facts
                    p
                        strong Main Contractor:&nbsp;
                        a(href="/") Montane Developments
                    p
                        strong Main Contractor:&nbsp;
                        a(href="/") Titan Roofing

    section.project-gallery
        .container
            .header
                .header-box(data-animation="reveal")
                    +tag('PROJECT GALLERY', 'blue')
                .header-box(data-animation="reveal" data-animation-delay="100")
                    h2 Explore the Project

            .slider-handler(data-animation="reveal" data-animation-delay="200")
                .embla__dots.blue
                .slider-controls
                    +prev
                    +next
            .slider-wrapper(data-animation="reveal" data-animation-delay="300")
                figure.slider-preview
                    img.image(src="/images/projects/gallery-1.png", alt="image")
                .embla.gallery-slider
                    .embla__container
                        each i in [2,1,2,1,2,1,2,1,2]
                            button.embla__slide
                                img.image(src=`/images/projects/gallery-${i}.png`, alt="image")

    section.testimonial
        .testimonial-header
            .header-box(data-animation="reveal")
                +tag('TESTIMONIALS', 'blue')
            .header-box(data-animation="reveal" data-animation-delay="100")
                h1
                    | Built on Trust,<br/>
                    span.blue Backed by Results.

        .embla.carousel-slider.centered(data-animation="reveal")
            .embla__container
                each i in [1,2]
                    .embla__slide.blue-slide
                        .slide-top
                            p.paragraph-xs
                                svg(width='70' height='14' viewBox='0 0 70 14' fill='none' xmlns='http://www.w3.org/2000/svg')
                                    path(d='m6.55 0 1.471 4.526h4.76L8.93 7.324l1.47 4.526-3.85-2.798L2.7 11.85l1.47-4.526L.32 4.526h4.76zM35 0l1.47 4.526h4.76l-3.85 2.798 1.47 4.526L35 9.052l-3.85 2.798 1.47-4.526-3.85-2.798h4.759zM20.777 0l1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76zm28.445 0 1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76zm14.227 0 1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76z' fill='currentColor')
                                | 4.7/5 Google Reviews
                            p.paragraph-xs October 13, 2024
                        .slide-header
                            h5 Niall Mc Donagh
                            h6
                                strong Niall McDonagh Roofing Services
                        .content-box
                            p “Laydex have been a trusted partner of ours for years. Their product range is excellent, and the technical support they provide makes a real difference on projects. Deliveries are always on time, communication is clear, and the team are a pleasure to deal with.
                            p We would happily recommend Laydex to anyone in the industry.”

                    .embla__slide.blue-slide
                        .slide-top
                            p.paragraph-xs
                                svg(width='70' height='14' viewBox='0 0 70 14' fill='none' xmlns='http://www.w3.org/2000/svg')
                                    path(d='m6.55 0 1.471 4.526h4.76L8.93 7.324l1.47 4.526-3.85-2.798L2.7 11.85l1.47-4.526L.32 4.526h4.76zM35 0l1.47 4.526h4.76l-3.85 2.798 1.47 4.526L35 9.052l-3.85 2.798 1.47-4.526-3.85-2.798h4.759zM20.777 0l1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76zm28.445 0 1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76zm14.227 0 1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76z' fill='currentColor')
                                | 4.7/5 Google Reviews
                            p.paragraph-xs October 13, 2024
                        .slide-header
                            h5 Brendan Walsh
                            h6
                                strong Director of Max roofing systems
                        .content-box
                            p “I have used RESITRIX now for four years on small and large contracts. It’s a fantasy material to work with. Easy to apply and most of all no time consuming metal on upstands or change of angle, no flame and fast installation. I would highly recommend it and beats other single Ply’s hands down.” Max Roofing

                    .embla__slide.blue-slide
                        .slide-top
                            p.paragraph-xs
                                svg(width='70' height='14' viewBox='0 0 70 14' fill='none' xmlns='http://www.w3.org/2000/svg')
                                    path(d='m6.55 0 1.471 4.526h4.76L8.93 7.324l1.47 4.526-3.85-2.798L2.7 11.85l1.47-4.526L.32 4.526h4.76zM35 0l1.47 4.526h4.76l-3.85 2.798 1.47 4.526L35 9.052l-3.85 2.798 1.47-4.526-3.85-2.798h4.759zM20.777 0l1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76zm28.445 0 1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76zm14.227 0 1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76z' fill='currentColor')
                                | 4.7/5 Google Reviews
                            p.paragraph-xs October 13, 2024
                        .slide-header
                            h5 PJ Costello
                            h6
                                strong Sterton Enterprises
                        .content-box
                            p “The results were class. I can’t believe it in all my years in roofing!”

    section.related
            .header
                .header-box(data-animation="reveal")
                    +tag('PRODUCTS', 'blue')
                .header-box(data-animation="reveal" data-animation-delay="100")
                    h2
                        | Related&nbsp;
                        span.blue Cases Studies
                    .slider-controls
                        +prev
                        +next

            .embla.carousel-slider(data-animation="reveal")
                .embla__container
                    each i in [1,2,3]
                        a.embla__slide.project-slide(href="/project-single.html")
                            figure.item-figure
                                img.image(src="/images/projects/p-1.png", alt="image")
                            .content-box
                                p.paragraph-sm Building Products
                                h4 Resitrix SK W & Sage Artificial Grass Residential Project. Private Dwelling
                                p.paragraph-sm This unique residential project was completed in 2022. The stunning private dwelling is complete with Resitrix SK W on the flat roof surfaces coupled with Sage...
                                .btns
                                    button.btn.border
                                        span.btn-box LEARN MORE
                                        .icon-box
                                            svg(width="10", height="11", viewBox="0 0 10 11", fill="none", xmlns="http://www.w3.org/2000/svg")
                                                path(d="m5.754.5 3.628 5-3.628 5H.98l3.413-4.706.212-.294-.212-.294L.98.5z", stroke="currentColor")

                        a.embla__slide.project-slide(href="/project-single.html")
                            figure.item-figure
                                img.image(src="/images/projects/p-2.png", alt="image")
                            .content-box
                                p.paragraph-sm Building Products
                                h4 Colm Quinn BMW Drogheda. Memtech R1 Radon Barrier Installation
                                p.paragraph-sm This commercial building project required the development of a new premises for Colm Quinn BMW at the M1 Retail Park in Drogheda, Co. Louth. This project...
                                .btns
                                    button.btn.border
                                        span.btn-box LEARN MORE
                                        .icon-box
                                            svg(width="10", height="11", viewBox="0 0 10 11", fill="none", xmlns="http://www.w3.org/2000/svg")
                                                path(d="m5.754.5 3.628 5-3.628 5H.98l3.413-4.706.212-.294-.212-.294L.98.5z", stroke="currentColor")

                        a.embla__slide.project-slide(href="/project-single.html")
                            figure.item-figure
                                img.image(src="/images/projects/p-3.png", alt="image")
                            .content-box
                                p.paragraph-sm Building Products
                                h4 St Mary’s Secondary School. Juta GP Titanbond Lift Pit Installation
                                p.paragraph-sm This project required an accessible lift for a local school in Ballina, Co. Mayo. Setting the foundations for this project, a lift pit installation was required to ensure this...
                                .btns
                                    button.btn.border
                                        span.btn-box LEARN MORE
                                        .icon-box
                                            svg(width="10", height="11", viewBox="0 0 10 11", fill="none", xmlns="http://www.w3.org/2000/svg")
                                                path(d="m5.754.5 3.628 5-3.628 5H.98l3.413-4.706.212-.294-.212-.294L.98.5z", stroke="currentColor")

    +contact-section
    +type-section
