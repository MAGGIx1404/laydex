extends /layouts/default

block content
    section.projects
        .container
            .content-box
                +tag('PROJECTS', 'orange')
                h2
                    | Proven Projects,&nbsp;
                    span.orange Trusted Solutions
                .btns-wrapper
                    button.link-outline.active(data-tab="all") VIEW ALL
                    button.link-outline(data-tab="1") BUILDING PRODUCTS
                    button.link-outline(data-tab="2") ROOFING
                    button.link-outline(data-tab="3") FLOORING
                    button.link-outline(data-tab="4") PASSIVE FIRE PROTECTION
                    button.link-outline(data-tab="5") RADON & GAS PROTECTION

            .projects-grid
                each i in [1,2,3]
                    a.project-card(href="/project-single.html" data-tab-content="1")
                        figure.item-figure
                            img.image(src="/images/projects/p-1.png", alt="image")
                        .content-box
                            p.paragraph-sm Building Products
                            h4 Resitrix SK W & Sage Artificial Grass Residential Project. Private Dwelling
                            p.paragraph-sm This unique residential project was completed in 2022. The stunning private dwelling is complete with Resitrix SK W on the flat roof surfaces coupled with Sage...
                            .btns
                                button.btn.border
                                    span.btn-box LEARN MORE
                                    .icon-box
                                        svg(width="10", height="11", viewBox="0 0 10 11", fill="none", xmlns="http://www.w3.org/2000/svg")
                                            path(d="m5.754.5 3.628 5-3.628 5H.98l3.413-4.706.212-.294-.212-.294L.98.5z", stroke="currentColor")

                    a.project-card(href="/project-single-2.html" data-tab-content="2")
                        figure.item-figure
                            img.image(src="/images/projects/p-2.png", alt="image")
                        .content-box
                            p.paragraph-sm Building Products
                            h4 Colm Quinn BMW Drogheda. Memtech R1 Radon Barrier Installation
                            p.paragraph-sm This commercial building project required the development of a new premises for Colm Quinn BMW at the M1 Retail Park in Drogheda, Co. Louth. This project...
                            .btns
                                button.btn.border
                                    span.btn-box LEARN MORE
                                    .icon-box
                                        svg(width="10", height="11", viewBox="0 0 10 11", fill="none", xmlns="http://www.w3.org/2000/svg")
                                            path(d="m5.754.5 3.628 5-3.628 5H.98l3.413-4.706.212-.294-.212-.294L.98.5z", stroke="currentColor")

                    a.project-card(href="/project-single-3.html" data-tab-content="3")
                        figure.item-figure
                            img.image(src="/images/projects/p-3.png", alt="image")
                        .content-box
                            p.paragraph-sm Building Products
                            h4 St Mary’s Secondary School. Juta GP Titanbond Lift Pit Installation
                            p.paragraph-sm This project required an accessible lift for a local school in Ballina, Co. Mayo. Setting the foundations for this project, a lift pit installation was required to ensure this...
                            .btns
                                button.btn.border
                                    span.btn-box LEARN MORE
                                    .icon-box
                                        svg(width="10", height="11", viewBox="0 0 10 11", fill="none", xmlns="http://www.w3.org/2000/svg")
                                            path(d="m5.754.5 3.628 5-3.628 5H.98l3.413-4.706.212-.294-.212-.294L.98.5z", stroke="currentColor")

    section.testimonial
        .testimonial-header
            .header-box
                +tag('TESTIMONIALS', 'orange')
            .header-box
                h1
                    | Trusted by Builders,<br/>
                    span.orange Architects and Contractors

        .embla.carousel-slider.centered
            .embla__container
                each i in [1,2]
                    .embla__slide
                        .slide-top
                            p.paragraph-xs
                                svg(width='70' height='14' viewBox='0 0 70 14' fill='none' xmlns='http://www.w3.org/2000/svg')
                                    path(d='m6.55 0 1.471 4.526h4.76L8.93 7.324l1.47 4.526-3.85-2.798L2.7 11.85l1.47-4.526L.32 4.526h4.76zM35 0l1.47 4.526h4.76l-3.85 2.798 1.47 4.526L35 9.052l-3.85 2.798 1.47-4.526-3.85-2.798h4.759zM20.777 0l1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76zm28.445 0 1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76zm14.227 0 1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76z' fill='currentColor')
                                | 4.7/5 Google Reviews
                            p.paragraph-xs October 13, 2024
                        .slide-header
                            h5 Niall Mc Donagh
                            h6
                                strong Niall McDonagh Roofing Services
                        .content-box
                            p “Laydex have been a trusted partner of ours for years. Their product range is excellent, and the technical support they provide makes a real difference on projects. Deliveries are always on time, communication is clear, and the team are a pleasure to deal with.
                            p We would happily recommend Laydex to anyone in the industry.”

                    .embla__slide
                        .slide-top
                            p.paragraph-xs
                                svg(width='70' height='14' viewBox='0 0 70 14' fill='none' xmlns='http://www.w3.org/2000/svg')
                                    path(d='m6.55 0 1.471 4.526h4.76L8.93 7.324l1.47 4.526-3.85-2.798L2.7 11.85l1.47-4.526L.32 4.526h4.76zM35 0l1.47 4.526h4.76l-3.85 2.798 1.47 4.526L35 9.052l-3.85 2.798 1.47-4.526-3.85-2.798h4.759zM20.777 0l1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76zm28.445 0 1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76zm14.227 0 1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76z' fill='currentColor')
                                | 4.7/5 Google Reviews
                            p.paragraph-xs October 13, 2024
                        .slide-header
                            h5 Brendan Walsh
                            h6
                                strong Director of Max roofing systems
                        .content-box
                            p “I have used RESITRIX now for four years on small and large contracts. It’s a fantasy material to work with. Easy to apply and most of all no time consuming metal on upstands or change of angle, no flame and fast installation. I would highly recommend it and beats other single Ply’s hands down.” Max Roofing

                    .embla__slide
                        .slide-top
                            p.paragraph-xs
                                svg(width='70' height='14' viewBox='0 0 70 14' fill='none' xmlns='http://www.w3.org/2000/svg')
                                    path(d='m6.55 0 1.471 4.526h4.76L8.93 7.324l1.47 4.526-3.85-2.798L2.7 11.85l1.47-4.526L.32 4.526h4.76zM35 0l1.47 4.526h4.76l-3.85 2.798 1.47 4.526L35 9.052l-3.85 2.798 1.47-4.526-3.85-2.798h4.759zM20.777 0l1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76zm28.445 0 1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76zm14.227 0 1.47 4.526h4.76l-3.85 2.798 1.47 4.526-3.85-2.798-3.85 2.798 1.47-4.526-3.85-2.798h4.76z' fill='currentColor')
                                | 4.7/5 Google Reviews
                            p.paragraph-xs October 13, 2024
                        .slide-header
                            h5 PJ Costello
                            h6
                                strong Sterton Enterprises
                        .content-box
                            p “The results were class. I can’t believe it in all my years in roofing!”

    +contact-section
